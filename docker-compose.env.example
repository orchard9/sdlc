# Hub dev environment variables.
# Copy to docker-compose.env and adjust as needed.
#
# Start the hub server with:
#   export $(cat docker-compose.env | xargs)
#   cargo watch -x 'run --bin ponder -- ui start --port 3141 --no-open --no-tunnel --hub'

# Required — Postgres connection for telemetry + orchestrator storage
DATABASE_URL=postgres://sdlc:sdlc@localhost:7781/sdlc

# Required — Gitea connection for repo listing
GITEA_URL=http://localhost:7782
GITEA_API_TOKEN=<run ./dev/setup-gitea.sh to generate>

# Required — hub mode flag
SDLC_HUB=true

# Required — project root (use a temp dir for hub since it has no real project)
SDLC_ROOT=/tmp/sdlc-hub

# Optional — Woodpecker CI (only if you uncommented woodpecker in docker-compose.yml)
# WOODPECKER_URL=http://localhost:8000
# WOODPECKER_API_TOKEN=<from woodpecker UI>
