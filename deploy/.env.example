# Telegram Digest Bot — Environment Configuration Template
#
# Copy this file to /opt/telegram-bot/.env on your host machine.
# Set all values before starting the services.
# Permissions: chmod 600 /opt/telegram-bot/.env
#
# NEVER commit the live .env file to git.

# ──────────────────────────────────────────────
# Telegram Bot Configuration
# ──────────────────────────────────────────────

# Bot token from @BotFather (https://t.me/BotFather)
# Format: <numeric-id>:<alphanumeric-token>
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────

# Path to the SQLite database file.
# The directory must exist and be writable by the telegram-bot user.
DATABASE_URL=/opt/telegram-bot/data/messages.db

# ──────────────────────────────────────────────
# SMTP Configuration (for digest emails)
# ──────────────────────────────────────────────

# SMTP server hostname
# Common: smtp.gmail.com, smtp.mailgun.org, smtp.sendgrid.net
SMTP_HOST=smtp.gmail.com

# SMTP port
# 587 = STARTTLS (recommended)
# 465 = SSL/TLS
# 25  = plain (not recommended)
SMTP_PORT=587

# SMTP login username (usually your email address)
SMTP_USER=your_email@gmail.com

# SMTP password or app-specific password
# For Gmail: generate an App Password at https://myaccount.google.com/apppasswords
SMTP_PASSWORD=your_app_password_here

# ──────────────────────────────────────────────
# Digest Configuration
# ──────────────────────────────────────────────

# Email address to send the daily digest to
DIGEST_RECIPIENT=recipient@example.com

# Sender display name (optional, used in From header)
DIGEST_FROM_NAME=Telegram Daily Digest
